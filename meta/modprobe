# modprobe@ is a META-COMMAND that calls modprobe(8).
# The argument should be the name of the kernel module you want to load.
# Example: modprobe@nvidia
# To enable modules at boot, do e.g. `dinitctl enable modprobe@nvidia`

type = scripted
command = /bin/modprobe -sv $1
restart = false
depends-on: early.target
