# We use a scripted service for eudev since (at least with eudev-3.1.2)
# there is no other way to get notification when the control socket is
# ready. (The downside is that we cannot properly supervise the process
# and restart it if it crashes).

type = scripted
command = /bin/eudevd -d
stop-command = /bin/eudevadm control -e
log-type = buffer
restart = false

waits-for: early.target
